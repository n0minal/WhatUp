# twilio-mock configuration (all optional; defaults in parentheses)

# PORT=4010
# WEBHOOK_URL=http://localhost:3000/webhooks/twilio/sms
# SERVICE_NUMBER=+15550000001

# Chaos knobs — real Twilio double-delivers and reorders webhooks; these make
# that reproducible so the backend's idempotency can be demonstrated.

# Chance (0..1) that an inbound webhook is delivered twice. 1 = every message
# is double-delivered; the backend must still produce exactly one reply. (0)
WEBHOOK_DUPLICATE_PROB=1

# Random extra delay per webhook delivery in ms; reorders bursts. (0)
# WEBHOOK_MAX_DELAY_MS=0
