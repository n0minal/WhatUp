{
  "name": "whatup",
  "private": true,
  "description": "Dev orchestration for the WhatUp monorepo — run `npm run dev` to start everything.",
  "workspaces": [
    "whatup-contracts",
    "whatup-backend",
    "whatup-admin",
    "twilio-mock"
  ],
  "scripts": {
    "dev": "docker compose up -d --wait && concurrently -k -n backend,twilio,admin -c blue,magenta,green \"npm run dev:backend\" \"npm run dev:twilio\" \"npm run dev:admin\"",
    "obs": "docker compose --profile obs up -d --wait lgtm",
    "obs:down": "docker compose --profile obs rm -sf lgtm",
    "dev:backend": "npm --prefix whatup-backend run start:dev",
    "dev:twilio": "npm --prefix twilio-mock run dev",
    "dev:admin": "VITE_API_URL=http://localhost:3000 VITE_TWILIO_MOCK_URL=http://localhost:4010 npm --prefix whatup-admin run dev",
    "postinstall": "npm run build --workspace whatup-contracts --if-present",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
