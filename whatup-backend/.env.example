# Run mode: api | worker | all (dev default: all — one process runs both)
APP_MODE=all
PORT=3000

# Postgres (docker-compose defaults)
DB_HOST=localhost
DB_PORT=5432
DB_USER=whatup
DB_PASSWORD=whatup
DB_NAME=whatup

# RabbitMQ (docker-compose defaults). Queues are asserted by the app:
# whatup-inbound, whatup-inbound.retry (delayed redelivery), whatup-inbound.dlq.
# The changes exchange fans change hints out to API instances for SSE.
RABBITMQ_URL=amqp://whatup:whatup@localhost:5672
RABBITMQ_QUEUE=whatup-inbound
RABBITMQ_CHANGES_EXCHANGE=whatup-changes
RABBITMQ_PREFETCH=5
RABBITMQ_RETRY_DELAY_MS=60000
RABBITMQ_MAX_RECEIVE_COUNT=3

# Messaging driver: twilio | zenvia | fake (fake logs sends in-process).
# Dev default: twilio against the twilio-mock service. Production: set
# TWILIO_API_BASE_URL=https://api.twilio.com and real credentials, or
# switch to the zenvia driver.
MESSAGING_DRIVER=twilio
TWILIO_API_BASE_URL=http://localhost:4010
TWILIO_ACCOUNT_SID=AC_fake
TWILIO_AUTH_TOKEN=fake
TWILIO_FROM_NUMBER=+15550000001
ZENVIA_API_BASE_URL=https://api.zenvia.com
ZENVIA_API_TOKEN=fake
ZENVIA_FROM_NUMBER=whatup

# Reply driver: fake (simulated delay, deterministic replies) | claude (LLM
# via the Claude Agent SDK). The claude driver uses the machine's Claude Code
# login, so usage draws from the Claude subscription plan — do NOT set
# ANTHROPIC_API_KEY (a key would switch billing to per-token API usage; the
# driver strips it from the subprocess env as a safeguard).
REPLY_DRIVER=fake
CLAUDE_MODEL=haiku
# Prior conversation turns passed to the reply driver as context
REPLY_HISTORY_LIMIT=20

# Fake-driver simulated delay (ms) and stale-claim takeover threshold (s)
PROCESSING_MIN_MS=3000
PROCESSING_MAX_MS=15000
STALE_CLAIM_SECONDS=90
